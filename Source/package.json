{
  "name": "password-vault",
  "productName": "PasswordVault",
  "version": "0.5.4",
  "description": "A Local Password Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.bishop.passwordvault.app",
    "productName": "PasswordVault",
    "artifactName": "${productName}Setup_${version}_${os}_${arch}.${ext}",
    "asar": true,
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "PasswordVault/assets/logos/passwordvault.ico"
    },
    "linux": {
      "target": "appImage",
      "icon": "PasswordVault/assets/logos/Password Vault Logo 512.png"
    },
    "portable": {
      "artifactName": "${productName}Portable_${version}_${os}_${arch}.${ext}"
    },
    "appImage": {
      "artifactName": "${productName}_${version}_${os}_${arch}.${ext}"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
